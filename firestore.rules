
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if true; // Prototyping
    }

    match /jobs/{jobId} {
      allow read: if true;
      allow write: if true; // Prototyping
      
      match /applications/{applicationId} {
        allow create: if true; // Public applications allowed for prototyping
        allow read, write: if true; // Admin access for prototyping
      }
    }

    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);

      match /orders/{orderId} {
        allow read, write: if isOwner(userId);
        
        match /orderItems/{itemId} {
          allow read, write: if isOwner(userId);
        }
      }
      
      match /shoppingCarts/{cartId} {
        allow read, write: if isOwner(userId);
        
        match /cartItems/{itemId} {
          allow read, write: if isOwner(userId);
        }
      }
    }

    match /roles_admin/{adminUid} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
    }
  }
}
